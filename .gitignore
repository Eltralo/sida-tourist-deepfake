# ── Model weights ─────────────────────────────────────────────────────────────
# Base model is too large for git (~13 GB). Download from HuggingFace:
#   huggingface-cli download Peterande/SIDA-7B --local-dir ck/SIDA-7B
ck/SIDA-7B/

# Duplicate SAM checkpoint (2.4 GB) — ck/sam_vit_h_4b8939.pth (30 MB) is kept
ck/sam_vit_h_4b8939.pth.1

# ── Feature cache ──────────────────────────────────────────────────────────────
# Regenerated by running: python detection/finetune.py
features_new/

# ── Dataset images ─────────────────────────────────────────────────────────────
# Not included — see dataset_generation/ to reproduce
dataset/
photo/

# ── Inference output ───────────────────────────────────────────────────────────
results/
results_final/masks/
results_final/overlays/
vis_output/
vis_output_eval/

# ── Generation logs ────────────────────────────────────────────────────────────
# JSON logs are large and contain job metadata with no reproducibility value
dataset_generation/**/*_log.json

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Environment ────────────────────────────────────────────────────────────────
.env
.env.*
*.local

# ── IDE ────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ─────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

